    }
}
,{
    "path": "uni_modules/uni-id-pages/pages/login/login-withpwd",
    "style": {
        "navigationBarTitleText": "账号密码登录"
    }
}
,{
    "path": "uni_modules/uni-id-pages/pages/login/login-smscode",
